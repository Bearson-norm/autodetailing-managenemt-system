# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autodetaailing
DB_USER=postgres
DB_PASSWORD=your_password

# Server (if Gunicorn/Flask uses 5000 on this machine, use e.g. PORT=5001 and match Nginx)
PORT=5000
NODE_ENV=development

# Session (use a random string in production)
SESSION_SECRET=your_secret_key_change_this

# CORS (browser origin; must match where users open the SPA)
CORS_ORIGIN=http://localhost:5173
# Production example: CORS_ORIGIN=https://your-domain.com

# File upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Web Push (VAPID) — generate: npx web-push generate-vapid-keys
# Public key is exposed to the browser via GET /api/push/vapid-public-key
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact for push services (mailto: or https URL)
VAPID_SUBJECT=mailto:admin@example.com
