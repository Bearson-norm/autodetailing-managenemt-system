# API URL (backend). Baked in at build time (`npm run build`).
# Local dev:
VITE_API_URL=http://localhost:5000/api

# Production on VPS (create `.env.production` on the server, same folder as package.json;
# do not commit secrets). If Nginx serves the SPA and proxies `/api` to Node, use same-origin:
# VITE_API_URL=/api
# Or the public API URL:
# VITE_API_URL=https://your-domain.com/api
