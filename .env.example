# API URL (backend). Baked in at build time (`npm run build`).
# Local dev (copy to `.env` or use defaults in src):
VITE_API_URL=http://localhost:5000/api

# Production: this repo includes `.env.production` with VITE_API_URL=/api so `vite build`
# calls https://your-domain/api/... in the browser (via Nginx → Node). Do not use localhost
# in production builds — the browser’s localhost is the user’s PC, not the VPS.
